{
  "name": "claude-hook-monitor",
  "version": "1.0.3",
  "description": "Multi-terminal Claude Code monitoring dashboard via HTTP hooks",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "build:win": "npx @yao-pkg/pkg . --targets node20-win-x64 --output dist/claude-monitor-win.exe",
    "build:mac": "npx @yao-pkg/pkg . --targets node20-macos-x64 --output dist/claude-monitor-mac",
    "build:mac-arm": "npx @yao-pkg/pkg . --targets node20-macos-arm64 --output dist/claude-monitor-mac-arm64",
    "build": "npm run build:win && npm run build:mac && npm run build:mac-arm"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node20-win-x64",
      "node20-macos-x64",
      "node20-macos-arm64"
    ]
  },
  "dependencies": {
    "express": "^4.21.0",
    "open": "^10.1.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@yao-pkg/pkg": "^6.14.1"
  }
}
